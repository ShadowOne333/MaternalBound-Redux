GeneralBakery_Do_Another_Transaction:	// Bakeries don't run this line
	eob

GeneralBakery_Chosen_Character_Inventory_Full:	//l_0xc5bb46
// arg = player name
	"@{name(0)} doesn't seem to be able to accept any more things." next
	"@Can someone else carry it?" linebreak
	eob

GeneralBakery_Bulk_Buy_Lots:

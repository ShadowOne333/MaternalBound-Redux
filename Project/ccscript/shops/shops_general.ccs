	"@Please come again." next
	eob

GeneralBakery_Not_Enough_Cash:		//l_0xc5baf1
	"@It seems like you don't have enough money." next
	eob

GeneralBakery_Whole_Party_Full_Inventory:	//l_0xc5bb02
	"@You have so many belongings...  You just can't carry any more!" wait linebreak
	eob

GeneralBakery_What_To_Sell:		// Bakeries don't purchase items
	eob

GeneralBakery_Confirm_Selling:		// Bakeries don't purchase items
	eob

GeneralBakery_Cancel_Selling:		// Bakeries don't purchase items

// NEW CODE
BulkBuy:
	counter(0)
	
	newline " " input(2) // If you want to add some decoration around the input selector, do it here
	
	store_registers
	if result_is(0) { call(Bulk_Buy_Change_Of_Mind) eob } // backed out of the selector / chose 0 
	load_registers
	if result_is(1) { ctoarg store_registers newline goto(Selected_Item_String_Pt2) } // chose just one 	
	load_registers

	//Maedaez's suggestion
	compare_result(6)
	goto_if_false(BulkBuy_Continue)
	call(Bulk_Buy_Lots)

	BulkBuy_Continue:
	load_registers

	ctoarg 
	store_registers
	counter(1) 
	act_to_wram
 	goto(BulkCheckLoop)

BulkCheckLoop: // adds dummy items / removes money until either your inventory is full, wallet cannot afford the item, or the loop is complete
	if full(0xFF) { wram_to_act counter(1) act_to_wram call(BulkErrorReset) call(Bulk_Buy_Full_Inventory) eob } // call the loop to reset the inventory and wallet
	load_registers 
	"[1D 0A 00]" // get item price 
	swap
	
	if not hasmoney(0) { wram_to_act counter(1) act_to_wram call(BulkErrorReset) call(Bulk_Buy_Not_Enough_Cash) eob } // call the loop to reset the inventory and wallet, with different dialogue
	if hasmoney(0) { takemoney(0) } // if you can afford it, take the money
	
	give(0xFF, dummyItem)  // give a dummy item
	
	wram_to_act // load the alt registers, which for now will be storing the loop check
	ctoarg // copy the loop count to arg
	inc // increase the amount of loops
	act_to_wram // save the new loop value
	
	if result_is_arg { counter(1) goto(BulkResetInv) }  // compare the count of loops to the input the user provided
	goto(BulkCheckLoop)
	
BulkResetInv: // removes the dummy items
	take(0xFF, dummyItem) // remove a dummy item
	swap
	ctoarg // standard loop increment stuff
	inc
	swap
	if result_is_arg { load_registers counter(1) store_registers ctoarg swap act_to_wram goto(BulkMainLoop)}
	goto(BulkResetInv)

BulkMainLoop: // gives the items to your party 
	load_registers
	give(0xFF, 0)
	
	call (Sound_Cash_Register)
	pause(5) // if you don't like this thing, remove this line and the prevous one, and add the sound stuff in the if statement below
	
	wram_to_act
	if result_is_arg { load_registers set(Has_Purchased) set(UnknownFlag1) open_wallet eob }
	
	inc
	swap
	ctoarg // standard loop increment stuff
	swap
	act_to_wram
	goto(BulkMainLoop)
	
BulkErrorReset: // removes the dummy items and refunds in the case that you cannot afford that many / do not have enough inventory slots
	load_registers
	"[1D 0A 00]" // get price of item
	swap
	givemoney(0) // refund 
	take(0xFF, dummyItem) // remove a dummy item
	
	wram_to_act
	swap
	ctoarg // standard loop increment stuff
	swap
	inc
	act_to_wram
	
	if result_is_arg { eob } // since we will be calling this, eob to return
	goto(BulkErrorReset)
//

command adr32 (a) "[{byte[0] a} {byte[1] a} {byte[2] a} 00]"
command ifgoto (num, target) "[06 {short num} {long target}]"
command cc09start (num) "[09 {byte num}]"
command check_if_greater_equal(number) "[18 07 {long number} 00]"
command char_num (char) "[19 10 {byte char}]"
command get_iteminfo (char, slot) "[19 19 {byte char} {byte slot}]"
command display_char_inv (n, char) "[1A 05 {byte n} {byte char}]"
command display_shop (num) "[1A 06 {byte num}]"
command false_goto (target) "[1B 02 {long target}]"
command true_goto (target) "[1B 03 {long target}]"
command act_to_wram "[1B 05]"
command wram_to_act "[1B 06]"
command no_space (char) "[1D 02 {byte char}]"
command item_sell_price (price) "[1D 0B {byte price}]"
command party_check (num) "[1D 19 {byte num}]"
command random_number(num) "[1D 21 {byte num}]"
command equip (char, itemslot) "[1F 83 {byte char} {byte itemslot}]"
command compare_result (value) "[18 07 {long value} 00]"
command goto_if_false (label) "[1B 02 {long label}]"
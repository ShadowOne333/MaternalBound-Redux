	" defense" linebreak
	"  changed "
	switch_goto(4)		//Checks the Defense stat of a particular party member
		switch_entry(Char1_Defense_Old)
		switch_entry(Char2_Defense_Old)
		switch_entry(Char3_Defense_Old)
		switch_entry(Char4_Defense_Old)
	goto(Char1_Defense_Old)


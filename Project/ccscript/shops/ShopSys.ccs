// NEW CODE
BulkBuy:
	counter(0)
	
	newline " " input(2) // If you want to add some decoration around the input selector, do it here
	
	store_registers
	if result_is(0) { call(Bulk_Buy_Change_Of_Mind) eob } // backed out of the selector / chose 0 
	load_registers
	if result_is(1) { ctoarg store_registers newline goto(Selected_Item_String_Pt2) } // chose just one 	
	load_registers

	//Maedaez's suggestion
	compare_result(6)
	goto_if_false(BulkBuy_Continue)
	call(Bulk_Buy_Lots)
	
	// if result_is(6) { call(Bulk_Buy_Lots) }
	// load_registers
	// if result_is(7) { call(Bulk_Buy_Lots) }
	// load_registers
	// if result_is(8) { call(Bulk_Buy_Lots) }
	// load_registers
	// if result_is(9) { call(Bulk_Buy_Lots) } 
	// load_registers

BulkBuy_Continue:
	load_registers

	ctoarg 
	store_registers
	counter(1) 
	store_registers_shared
 	goto(BulkCheckLoop)

BulkCheckLoop:	// Adds dummy items / removes money until either your inventory is full, wallet cannot afford the item, or the loop is complete
	if full(-1) {	// Call the loop to reset the inventory and wallet
		load_registers_shared 
		counter(1)
		store_registers_shared
		call(BulkErrorReset)
		call(Bulk_Buy_Full_Inventory)
		eob
	}
	load_registers 
	get_buying_price(0)
	swap
	
	if cannot_take_money(0) {	// Call the loop to reset the inventory and wallet, with different dialogue
		load_registers_shared
		counter(1)
		store_registers_shared
		call(BulkErrorReset)
		call(Bulk_Buy_Not_Enough_Cash)
		eob
	}
	if hasmoney(0) { takemoney(0) } // if you can afford it, take the money
	
	give(-1, dummyItem)  // give a dummy item
	
	load_registers_shared // load the alt registers, which for now will be storing the loop check
	ctoarg // copy the loop count to arg
	inc // increase the amount of loops
	store_registers_shared // save the new loop value
	
	if result_is_arg {	// Compare the count of loops to the input the user provided
		counter(1)
		goto(BulkResetInv)
	}
	goto(BulkCheckLoop)
	
BulkResetInv: // removes the dummy items
	take(-1, dummyItem) // remove a dummy item
	swap
	ctoarg // standard loop increment stuff
	inc
	swap
	if result_is_arg {
		load_registers
		counter(1)
		store_registers
		ctoarg
		swap
		store_registers_shared
		goto(BulkMainLoop)
	}
	goto(BulkResetInv)

BulkMainLoop: // gives the items to your party 
	load_registers
	give(-1, 0)
	
	call(Sound_Cash_Register)
	pause(5) // if you don't like this thing, remove this line and the prevous one, and add the sound stuff in the if statement below
	
	load_registers_shared
	if result_is_arg {
		load_registers
		set(Has_Purchased)
		set(UnknownFlag1)
		open_wallet
		eob
	}
	
	inc
	swap
	ctoarg // standard loop increment stuff
	swap
	store_registers_shared
	goto(BulkMainLoop)
	
BulkErrorReset: // removes the dummy items and refunds in the case that you cannot afford that many / do not have enough inventory slots
	load_registers
	get_buying_price(0)
	swap
	givemoney(0) // refund 
	take(-1, dummyItem) // remove a dummy item
	
	load_registers_shared
	swap
	ctoarg // standard loop increment stuff
	swap
	inc
	store_registers_shared
	
	if result_is_arg { eob } // since we will be calling this, eob to return
	goto(BulkErrorReset)
//

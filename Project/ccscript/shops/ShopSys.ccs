// SETUP:
// Add `ShopSys.CompareResToArg` to CCExpand's control code tree,
// then change this define here to the control code it is at.
// Then, the command `result_is_arg` can be used in scripts.

define CC_Result_Is_Arg = "[1A 0C]"


command result_is_arg { CC_Result_Is_Arg }
// ASM function for comparing the result register to the argument register. By cooprocks123e. Thanks!
CompareResToArg: M_EB_Function_Wrapper({
    JSL   (R_Get_Working_Memory)
    // Move value from $06 to $00 temporarily
    LDA_d (0x06)
    STA_d (0x00)
    LDA_d (0x08)
    STA_d (0x02)
    JSL   (R_Get_Argument_Memory)
    // Initialize output value to 0
    STZ_d (0x0e)
    STZ_d (0x10)
    // Co mpare arg in $06 with working memory in $00
    LDX_d (0x06)
    CPX_d (0x00)
    // If not equal, we're done - return 0
    BNE_a (done)
    // Compare high word
    LDX_d (0x08)
    CPX_d (0x02)
    // If not equal, we're done - return 0
    BNE_a (done)
    // If we're here then Arg == Working - set return value to 1
    INC_d (0x0e)
done:
    // Write return value into working memory
    JSL   (R_Set_Working_Memory)
})

// Internal use
define Has_Purchased = flag 0x291      // Seemingly marks if you've already purchased something or not, for dialogue. Unsure how it is set, but it is checked
define Offense_Or_Defense = flag 0x292 // Seemingly marks if offense or defense is to change when equipping an item. Unsure how it is set, but it is checked
define UnknownFlag1 = flag 0xE0        // Something to do with if you've purchased or not? Unsure why or how it is seperate from Has_Purchased. Unsure how it is set.
define UnknownFlag2 = flag 0xE1        // Something to do with if you've sold or not?
//


//------------------------------------------------------------------
// Burglin Park Tool shop
//------------------------------------------------------------------
TwosonBurglinTools_Greeting:		//l_0xc5b625
	"@Hey mon!  You got to expand your mind an' use this stuff creatively." next
	"@C'mon, buy some of my junk!" linebreak
	eob

TwosonBurglinTools_Exit_Store_Buy:	//l_0xc5b666
	"@Take care, mon!" end

TwosonBurglinTools_Exit_Store_Dont_Buy:	//l_0xc5b674
	"@Ah scientific mon mig be able to mek gud use of dis ting here..." end

TwosonBurglinTools_Open_Shop_Window:	//l_0xc5b69d
	"@So, what would you like, mon?" promptw
	eob

TwosonBurglinTools_Selected_Item:	//l_0xc5b6af
	"@{itemname(0)}?" next
	if flag FLG_TOOL_ITEMS {
		swap
		result_is(BROKEN_IRON)
		goto_if_true(_is_broken_iron)
	}
	eob

_is_broken_iron:
	set(FLG_ITEM_BROKEN_IRON_PURCHASED)
	eob

TwosonBurglinTools_Who_Will_Take_Item:	//l_0xc5b6b7
	"@Who's goin' to take it?" promptw
	eob

TwosonBurglinTools_Equip_Now:		//l_0xc5b6ca
	"@Thank you, mon." next
	"@Do you want to equip that here then?" linebreak
	eob

TwosonBurglinTools_Buy_Previous_Equipment:	//l_0xc5b6e2
 // arg: item name, res: item price
	"@Would you be liking me to buy" linebreak
	"  your {itemname(0)}" linebreak
	"  for {swap}$" number(0) "?" next
	eob

TwosonBurglinTools_Cant_Equip_Item:	//l_0xc5b70b
// arg: player name
	"@{name(0)} cannot equip this here thing." next
	"@Are you still willing to buy it?" linebreak
	eob

TwosonBurglinTools_Cancel_Cant_Equip:	//l_0xc5b72d
// despite the name, it's often used as a generic change of mind
	"@Ah, I see mon.  That's too bad." next
	eob

TwosonBurglinTools_Not_Enough_Cash:	//l_0xc5b746
	"@Ah, mon, you are short of the green stuff, if you know what I mean, mon." next
	eob

TwosonBurglinTools_Whole_Party_Full_Inventory:	//l_0xc5b76f
	"@Well, you're straining with too many things now." next
	"@I'll buy the things you don't need, mon." linebreak
	eob

TwosonBurglinTools_What_To_Sell:	//l_0xc5b799
	"@What is it you want to sell, mon?" promptw
	eob

TwosonBurglinTools_Confirm_Selling:	//l_0xc5b7a6
// arg: item ID, res: item sell price
	"@{itemname(0)}?" linebreak
	"  Oh, I can give you" linebreak
	"  about {swap}$" number(0) ", OK?" next
	eob

TwosonBurglinTools_Cancel_Selling:	//l_0xc5b7cd
	"@Not goin' to go for it, eh mon?  No problem." next
	eob

TwosonBurglinTools_Nothing_To_Sell:	//l_0xc5b7f2
	"@But look, you don't have any things to sell!" next
	eob

TwosonBurglinTools_Unsellable_Item:	//l_0xc5b807
	"@Hold on, mon.  We don't carry that kind of stuff." next
	eob

TwosonBurglinTools_Transaction_Thanks:	//l_0xc5b826
	"@Thanks a lot, mon." next
	eob

TwosonBurglinTools_Transaction_Thanks_2:	//l_0xc5b833
// when is this used?
	"@There you go." linebreak
	"  Thanks a lot, mon." next
	eob

TwosonBurglinTools_Request_Another_Transaction:	//l_0xc5b84e
	"@Is there anything else you need, mon?" linebreak
	eob

TwosonBurglinTools_Do_Another_Transaction:	//l_0xc5b860
	"@Lay it on me." linebreak
	eob

TwosonBurglinTools_Chosen_Character_Inventory_Full:	//l_0xc5b86d
	"@Oh, {name(0)} has too many things already." next
	"@Won't one of your friends carry it for you?" linebreak
	eob

TwosonBurglinTools_Bulk_Buy_Lots:
	"@All these?" next eob

TwosonBurglinTools_Bulk_Buy_Not_Enough_Cash:
	"@Ah, mon, you are short of the green stuff, if you know what I mean, mon." next
	eob

TwosonBurglinTools_Bulk_Buy_Full_Inventory:
	"@Well, you're straining with too many things now." next
	"@I'll buy the things you don't need, mon." linebreak
	eob

TwosonBurglinTools_Bulk_Buy_Change_Of_Mind:
	"@Ah, I see mon.  That's too bad." next
	eob

//------------------------------------------------------------------
// Burglin Park Banana lady
//------------------------------------------------------------------
TwosonBurglinBanana_Greeting:		//l_0xc5cd18
	"@Hey kid!" next
	"@Would you like some bananas?" next
	eob

TwosonBurglinBanana_Exit_Store_Buy:	//l_0xc5cd29
	"@Thank you." end

TwosonBurglinBanana_Exit_Store_Dont_Buy:	//l_0xc5cd2f
	"@Well, when you want to eat bananas, I'll be here, selling them!" end

TwosonBurglinBanana_Open_Shop_Window:	//l_0xc5cd51
	//"@Hey kid!" next	// Moved to Greeting line so it doesn't sound awkward
	"@Do you want to buy some?" next
	eob

TwosonBurglinBanana_Selected_Item:	//l_0xc5cd64
	"@You want" linebreak
	"  the {itemname(0)}?" next
	eob

TwosonBurglinBanana_Who_Will_Take_Item:	//l_0xc5cd73
	"@Who is going to carry it?" promptw
	eob

TwosonBurglinBanana_Equip_Now:		// Banana lady doesn't sell equippables
	eob

TwosonBurglinBanana_Buy_Previous_Equipment:	// Banana lady doesn't sell equippables
	eob

TwosonBurglinBanana_Cant_Equip_Item:	// Banana lady doesn't sell equippables
	eob

TwosonBurglinBanana_Cancel_Cant_Equip:	//l_0xc5cd7f
// despite the name, it's often used as a generic change of mind
	"@You don't want any?  Whatever you say." end

TwosonBurglinBanana_Not_Enough_Cash:	//l_0xc5cd97
	//load_registers
	"@You can't buy the bananas if you don't have enough money." end

TwosonBurglinBanana_Whole_Party_Full_Inventory:	//l_0xc5cdb3
	"@You cannot carry any more." end

TwosonBurglinBanana_What_To_Sell:	// Banana lady doesn't purchase items
	eob

TwosonBurglinBanana_Confirm_Selling:	// Banana lady doesn't purchase items
	eob

TwosonBurglinBanana_Cancel_Selling:	// Banana lady doesn't purchase items
	eob

TwosonBurglinBanana_Nothing_To_Sell:	// Banana lady doesn't purchase items
	eob

TwosonBurglinBanana_Unsellable_Item:	// Banana lady doesn't purchase items
	eob

TwosonBurglinBanana_Transaction_Thanks:	//l_0xc5cdc0
	"@Thank you, thank you." next
	eob

TwosonBurglinBanana_Transaction_Thanks_2:	//l_0xc5cdcc
// when is this used?
	"@Thank you, thank you." next
	eob

TwosonBurglinBanana_Request_Another_Transaction:	//l_0xc5cdd8
	"@I have more bananas...  Do you want some more?" linebreak
	eob

TwosonBurglinBanana_Do_Another_Transaction:		// Banana lady doesn't run this line
	eob

TwosonBurglinBanana_Chosen_Character_Inventory_Full:	//l_0xc5cdf2
	"@{name(0)} has too many things to carry a banana." next
	"@Will someone else carry it for " swap call(0xc7e6a4) "?" linebreak
	eob

TwosonBurglinBanana_Bulk_Buy_Lots:
	"@All these bananas?" next eob

TwosonBurglinBanana_Bulk_Buy_Not_Enough_Cash:
	//load_registers
	"@You can't buy bananas if you don't have enough money." end

TwosonBurglinBanana_Bulk_Buy_Full_Inventory:
	"@You cannot carry any more." end

TwosonBurglinBanana_Bulk_Buy_Change_Of_Mind:
	"@You don't want any?  Whatever you say." end
	eob


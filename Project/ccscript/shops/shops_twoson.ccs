//------------------------------------------------------------------
import "../definitions/flags.ccs"
import "../essential/asm65816.ccs"
import "../expansion/ccexpand.ccs"
import "../essential/commands.ccs"
import "../essential/stdext.ccs"
//------------------------------------------------------------------
// Twoson drugstore
//------------------------------------------------------------------
TwosonDrugstore_Greeting:		//l_0xc5211e
	"@Hi!" next
	"@Can I help you?" linebreak
	eob

TwosonDrugstore_Exit_Store_Buy:		//l_0xc52130
	"@Thanks so much!" end

TwosonDrugstore_Exit_Store_Dont_Buy:	//l_0xc52139
	"@Are you here just to say <Hi>?  What a loser!" end

TwosonDrugstore_Open_Shop_Window:	//l_0xc52154
	"@So, what are you going to buy?" promptw
	eob

TwosonDrugstore_Selected_Item:		//l_0xc52163
	"@{itemname(0)}?" next
	eob

TwosonDrugstore_Who_Will_Take_Item:	//l_0xc5216b
	"@Who's going to carry this?" promptw
	eob

TwosonDrugstore_Equip_Now:		//l_0xc5217a
	"@Would you like to equip it here?" linebreak
	eob

TwosonDrugstore_Buy_Previous_Equipment:	//l_0xc52189
 // arg: item name, res: item price
	"@Do you want me to buy" linebreak
	"  your {itemname(0)}" linebreak
	"  for {swap}$" number(0) "?" next
	eob

TwosonDrugstore_Cant_Equip_Item:	//l_0xc521aa
// arg: player name
	"@Even though {name(0)} can't equip this," next
	"@do you still want to purchase it?" linebreak
	eob

TwosonDrugstore_Cancel_Cant_Equip:	//l_0xc521d3
// despite the name, it's often used as a generic change of mind
	"@Please come again." next
	eob

TwosonDrugstore_Not_Enough_Cash:	//l_0xc521dc
	"@I'm sorry, but you don't have enough money." next
	eob

TwosonDrugstore_Whole_Party_Full_Inventory:	//l_0xc521ec
	"@Oh, how are you planning to carry this?  You've got too much stuff!" next
	"@Well, I guess I could buy the stuff you don't need." next
	"@Do you want to sell anything?" linebreak
	eob

TwosonDrugstore_What_To_Sell:		//l_0xc5222e
	"@What can you sell me?" promptw
	eob

TwosonDrugstore_Confirm_Selling:	//l_0xc5223c
// arg: item ID, res: item sell price
	"@{itemname(0)}?" linebreak
	"  I'll pay {swap}$" number(0) " for it." next
	"@Is that okay?" linebreak
	eob

TwosonDrugstore_Cancel_Selling:		//l_0xc52261
	"@Hummm.  Is that so?" next
	eob

TwosonDrugstore_Nothing_To_Sell:	//l_0xc52272
	"@Oh, so you don't really have anything to sell?" next
	eob

TwosonDrugstore_Unsellable_Item:	//l_0xc52288
	"@I'm sorry, but I can't buy that." next
	eob

TwosonDrugstore_Transaction_Thanks:	//l_0xc52299
	"@Thank you very much." next
	eob

TwosonDrugstore_Transaction_Thanks_2:	//l_0xc522a3
// when is this used?
	"@Thank you." next
	eob

TwosonDrugstore_Request_Another_Transaction:	//l_0xc522aa
	"@Is there anything I can do for you?" linebreak
	eob

TwosonDrugstore_Do_Another_Transaction:	//l_0xc522ba
	"@What can I do for you now?" linebreak
	eob

TwosonDrugstore_Chosen_Character_Inventory_Full:	//l_0xc522ca
	"@{name(0)} can't carry any more." next
	"@Will another one of you take it?" linebreak
	eobs

TwosonDrugstore_Bulk_Buy_Lots:
	"@All of these?" next eob

TwosonDrugstore_Bulk_Buy_Not_Enough_Cash:
	"@I'm sorry, but you don't have enough money for all that." next
	eob

TwosonDrugstore_Bulk_Buy_Full_Inventory:
	"@Oh, how are you planning to carry these?  You've got too much stuff!" next
	"@Well, I guess I could buy the stuff you don't need." next
	"@Do you want to sell anything?" linebreak
	eob

TwosonDrugstore_Bulk_Buy_Change_Of_Mind:
	"@Please come again." next
	eob

//------------------------------------------------------------------
// Burglin Park Bakery shop
//------------------------------------------------------------------
TwosonBurglinBakery_Greeting:		//l_0xc5bc70
	"@I like to sell my goodies on the street." next
	"@Sure, flies land on them, but in my opinion, it makes them taste even better!" next
	eob

TwosonBurglinBakery_Exit_Store_Buy:	//l_0xc5bcc2
	"@Thanks a lot." end

TwosonBurglinBakery_Exit_Store_Dont_Buy:	//l_0xc5bcca
	"@Please come again." end

TwosonBurglinBakery_Open_Shop_Window:	//l_0xc5bcd2
	"@What would you like?" promptw
	eob

TwosonBurglinBakery_Selected_Item:	//l_0xc5bcdd
	"@{itemname(0)}?" next
	eob

TwosonBurglinBakery_Who_Will_Take_Item:	//l_0xc5bce5
	"@Who is going to carry this?" promptw
	eob

TwosonBurglinBakery_Equip_Now:		// Bakeries don't sell equippables
	eob

TwosonBurglinBakery_Buy_Previous_Equipment:	// Bakeries don't sell equippables
	eob

TwosonBurglinBakery_Cant_Equip_Item:	// Bakeries don't sell equippables
	eob

TwosonBurglinBakery_Cancel_Cant_Equip:	//l_0xc5bcf4
// despite the name, it's often used as a generic change of mind
	"@Please come again." next
	eob

TwosonBurglinBakery_Not_Enough_Cash:	//l_0xc5bcfd
	"@It looks like you don't have enough money." next
	eob

TwosonBurglinBakery_Whole_Party_Full_Inventory:	//l_0xc5bd0c
	"@You are already carrying too much stuff." next
	"@You should sell some things, or throw them away, or just leave them somewhere." end

TwosonBurglinBakery_What_To_Sell:	// Bakeries don't purchase items
	eob

TwosonBurglinBakery_Confirm_Selling:	// Bakeries don't purchase items
	eob

TwosonBurglinBakery_Cancel_Selling:	// Bakeries don't purchase items
	eob

TwosonBurglinBakery_Nothing_To_Sell:	// Bakeries don't purchase items
	eob

TwosonBurglinBakery_Unsellable_Item:	// Bakeries don't purchase items
	eob

TwosonBurglinBakery_Transaction_Thanks:		//l_0xc5bd49
	"@Thank you very much." next
	eob

TwosonBurglinBakery_Transaction_Thanks_2:	//l_0xc5bd53
// when is this used?
	"@Thanks." next
	eob

TwosonBurglinBakery_Request_Another_Transaction:	//l_0xc5bd59
	"@Do you want to buy anything else?" linebreak
	eob

TwosonBurglinBakery_Do_Another_Transaction:		// Bakeries don't run this line
	"@What can I do for you now?" linebreak
	eob

TwosonBurglinBakery_Chosen_Character_Inventory_Full:	//l_0xc5bd62
	"@{name(0)} is carrying too many things already." next
	"@Can anyone else carry it for " swap call(0xc7e6a4) "?" linebreak
	eob

TwosonBurglinBakery_Bulk_Buy_Lots:
	"@All of these?" next eob

TwosonBurglinBakery_Bulk_Buy_Not_Enough_Cash:
	"@It looks like you don't have enough money for these." next
	eob

TwosonBurglinBakery_Bulk_Buy_Full_Inventory:
	"@You are already carrying too much stuff." next
	"@You should sell some things, or throw them away, or just leave them somewhere." end

TwosonBurglinBakery_Bulk_Buy_Change_Of_Mind:
	"@Please come again." next
	eob


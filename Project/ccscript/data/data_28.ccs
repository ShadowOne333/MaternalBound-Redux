l_0xc70511:
	"@It seems that the citizens of Onett have been harassed" next
	"@by those dang street punks called the Sharks." next
	"@I wonder if going and talking to Frank," next
	"@the leader of the Sharks, would do any good?"
	call(data_29.l_0xc726cb)
	eob

l_0xc7058d:
	"@So, have you met B. H. Pirkle, the mayor of Onett?" next
	"@Mayor Pirkle's office is on the second floor of Onett City Hall."
	call(data_29.l_0xc726cb)
	eob

l_0xc705e4:
	"@Go northwest." next
	"@A traveling entertainer is having some trouble getting into a locked shack..."
	call(data_29.l_0xc726cb)
	eob


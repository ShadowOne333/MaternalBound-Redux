	pause(60)
	window_open(1)
	title(1, Mom)
	"@{name(1)}...|| he smiled just from hearing his own name." next
	"@Do you think he likes his name?" promptw
	window_closeall

	pause(120)
	window_open(1)
	title(1, Dad)
	"@Try putting that red cap on him." next
	"@Ha ha ha!" linebreak
	"  It's too big, but it looks good on him..." promptw
	window_closeall

	pause(60)
	window_open(1)
	title(1, Mom)
	"@I hope {stat(3)} won't be jealous of the baby." promptw	// Dog name
	window_closeall

	pause(120)
	window_open(1)
	title(1, Dad)
	"@Let's celebrate with some {stat(4)}." next	// Fav food
	"@This baby will grow up to be a hard worker just like you." promptw
	window_closeall

	pause(60)
	window_open(1)
	title(1, Mom)
	"@I don't think he needs to be rich or famous..." next
	"@but I want him to be a thoughtful, strong boy." next
	window_closeall

	pause(60) pause(60) pause(60)
	window_open(1)
	title(1, Mom)
	"@That's odd.../| the baby bottle that he pointed at seemed to move a little bit..." next
	"@Hmmm..." wait

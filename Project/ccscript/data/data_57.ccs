	warp(81)	// 0x51
	pause(30)
	event(16)	// 0x10, Final unskippable Sound stone screen
	pause(30)
	sprite2_spawn(435,695,-1)	// 0x01B3, 0x02B7, 0xFF
	warp(35)	// 0x23

command Use_Action( BattleActionID ) {
	reset_action
	set_action(BattleActionID)
	ret_target
	JML	(0xC23B4D)	// @UNKNOWN112, End of Battle menu selections
}

command CC_Use_Battle_Action( BattleActionID ) {	// 0xC239C9
	LDA_i	(BattleActionID)	// Spy battle action
	STA_d	(0x02)
	STA_d	(0x1E)

	LDA_d   (0x02)		// 0x02
	STA_a	(0xA97F)	// BATTLE_MENU_SELECTION + battle_menu_selection::selected_action
	SEP	(0x20)
	LDA_8	(0x11)
	STA_a	(0xA981)	// BATTLE_MENU_SELECTION + battle_menu_selection::targetting

	LDY_d   (0x02)		// 0x02
	LDX_i	(0x0001)
	REP	(0x20)

	// Added so the Inventory window does not cover up the enemy when targetting
	LDA_i	(INVENTORY_WINDOW)
	JSL	(CLOSE_WINDOW)

	LDA_i	(0)
	LDX_i	(1)
	JSL	(0xC1DE37)	// REDIRECT_C1242E
}*/

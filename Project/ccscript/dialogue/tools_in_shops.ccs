//------------------------------------------------------------------

Check_Inventories:
	open_hp
	party_size_smaller_than(2)
	goto_if_true(Two_Members)
	select_char(Ness_Inv, Paula_Inv, Jeff_Inv, Pu_Inv, 0)
	rtoarg
	goto_if_false(Close_and_Switch)
	count_loaded_strings(2)
	goto_if_false(Check_Inventories)
	do_menu_in_window(2)
	goto_if_false(Check_Inventories)
	goto(Close_and_Switch)

Two_Members:
	get_char_at_pos(1)
	rtoarg
	store_registers_shared
	back_up_text_rendering_state
	load_registers_shared
	show_inventory(2,0)
	load_registers_shared
	do_menu_in_window(2)
	store_registers_shared
	window_switch(2)
	window_closetop
	window_switch(1)
	load_registers_shared
	goto_if_false(_end)
	swap
_end:
	eob

Ness_Inv:
	back_up_text_rendering_state
	show_inventory(2,1)
	eob

Paula_Inv:
	back_up_text_rendering_state
	show_inventory(2,2)
	eob

Jeff_Inv:
	back_up_text_rendering_state
	show_inventory(2,3)
	eob

Pu_Inv:
	back_up_text_rendering_state
	show_inventory(2,4)
	eob

Close_and_Switch:
	window_switch(2)
	window_closetop
	window_switch(1)
	swap
	eob
